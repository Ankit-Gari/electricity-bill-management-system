# Server
PORT=5000

# PostgreSQL (Homebrew installs use your macOS username with no password)
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_postgres_user
DB_PASSWORD=
DB_NAME=electricity

# Auth — use a long random string in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=change_me_to_a_long_random_string
